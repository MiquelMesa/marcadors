{
  "name": "marcadors",
  "version": "1.0.0",
  "description": "Gestor de marcadors i enllaços amb classificació automàtica per categories",
  "private": true,
  "scripts": {
    "start": "node server.js",
    "start:prod": "NODE_ENV=production node server.js",
    "pm2:start": "pm2 start ecosystem.config.js --env production",
    "pm2:stop": "pm2 stop marcadors",
    "pm2:restart": "pm2 restart marcadors",
    "pm2:logs": "pm2 logs marcadors",
    "test": "jest",
    "lint": "eslint .",
    "format": "prettier --write \"**/*.{js,json,css,html}\"",
    "tauri": "tauri",
    "build:sea": "powershell -ExecutionPolicy Bypass -File scripts/build-sea.ps1",
    "tauri:build": "npm run build:sea && npx tauri build"
  },
  "dependencies": {
    "dotenv": "^16.6.1",
    "express": "^5.2.1",
    "express-rate-limit": "^7.5.0",
    "pino": "^9.6.0"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2",
    "eslint": "^8.57.0",
    "jest": "^29.7.0",
    "pino-pretty": "^13.0.0",
    "prettier": "^3.4.0"
  }
}
