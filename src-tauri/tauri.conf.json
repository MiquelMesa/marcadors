{
  "$schema": "https://raw.githubusercontent.com/tauri-apps/tauri/dev/crates/tauri-cli/schema.json",
  "productName": "Marcadors",
  "version": "1.0.0",
  "identifier": "com.marcadors.desktop",
  "build": {
    "beforeDevCommand": "node server.js",
    "devUrl": "http://localhost:3000/marcadores/",
    "frontendDist": "../frontend"
  },
  "app": {
    "windows": [],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico"
    ],
    "resources": [
      "server.exe",
      "../.env",
      "../reglas.json",
      "../reglas.default.json",
      "../index.html",
      "../style.css",
      "../js/**/*",
      "../pin.png"
    ]
  }
}
