# ── Configuración de la aplicación ──

# Puerto donde escucha el servidor Node.js (default: 3000)
PORT=3000

# Ruta base para servir la app (vacío = raíz del dominio)
# Ejemplo: /marcadores  →  https://michaelprojects.org/marcadores/
BASE_PATH=/marcadores

# Ruta pública que ve el navegador (para construir URLs en JS)
# Normalmente igual que BASE_PATH
PUBLIC_PATH=/marcadores

# Nivel de log: fatal, error, warn, info, debug, trace (default: info)
LOG_LEVEL=info
